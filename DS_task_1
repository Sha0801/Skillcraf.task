import numpy as np
import matplotlib.pyplot as plt
import pandas as pd
import seaborn as sns  # Optional, for styling

# Sample data: 1000 people with ages and genders
np.random.seed(42)  # For reproducibility
ages = np.random.normal(40, 12, 1000).astype(int)  # Continuous ages
ages = np.clip(ages, 18, 70)  # Realistic range
genders = np.random.choice(['Male', 'Female'], 1000, p=[0.52, 0.48])  # Categorical genders

df = pd.DataFrame({'age': ages, 'gender': genders})

# Histogram for age distribution (continuous variable)
fig, ax = plt.subplots(figsize=(10, 6))
ax.hist(df['age'], bins=20, edgecolor='black', alpha=0.7, color='skyblue')
ax.set_xlabel('Age')
ax.set_ylabel('Frequency')
ax.set_title('Age Distribution in Population')
plt.tight_layout()
plt.savefig('age_histogram.png', dpi=300, bbox_inches='tight')
plt.show()  # Displays in notebook; optional

# Bar chart for gender distribution (categorical variable)
fig, ax = plt.subplots(figsize=(8, 5))
gender_counts = df['gender'].value_counts()
bars = ax.bar(gender_counts.index, gender_counts.values, 
              color=['skyblue', 'lightcoral'], edgecolor='black')
ax.set_xlabel('Gender')
ax.set_ylabel('Count')
ax.set_title('Gender Distribution in Population')

# Add value labels on bars for clarity
for bar, count in zip(bars, gender_counts.values):
    ax.text(bar.get_x() + bar.get_width()/2, bar.get_height() + 5, 
            str(count), ha='center', va='bottom')

plt.tight_layout()
plt.savefig('gender_barchart.png', dpi=300, bbox_inches='tight')
plt.show()  # Displays in notebook; optional
